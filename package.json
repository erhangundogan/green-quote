{
  "name": "greenquote",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @greenquote/web dev",
    "build": "yarn workspaces foreach -A -t run build",
    "test": "yarn workspace @greenquote/web test",
    "test:e2e": "yarn workspace @greenquote/web test:e2e",
    "test:e2e:report": "yarn workspace @greenquote/web test:e2e:report",
    "lint": "yarn workspaces foreach -A run lint",
    "typecheck": "yarn workspaces foreach -A run typecheck",
    "db:migrate": "yarn workspace @greenquote/web db:migrate",
    "db:seed": "yarn workspace @greenquote/web db:seed"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
