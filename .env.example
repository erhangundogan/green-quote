# Optional overrides for docker compose.
# Without this file, docker compose uses a local PostgreSQL container automatically.
# Copy to .env only if you want to override the defaults (e.g. point to Neon).

# Override with a Neon URL to use cloud PostgreSQL instead of the local db service:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Override with a strong random secret in production (openssl rand -base64 32):
# JWT_SECRET=replace-with-a-strong-random-secret
