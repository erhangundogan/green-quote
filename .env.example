# Copy this file to .env and fill in the values before running docker compose.
# The .env file is gitignored — never commit real credentials.

# PostgreSQL connection string (e.g. from Neon: https://console.neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-strong-random-secret
